@startuml tiket
skinparam classAttributeIconSize 0

class Main {
    + main(args: String[]): void
}

package controller {
    class AuthController {
        - authService: AuthService
        - currentUser: User
        + AuthController(service: AuthService)
        + login(username: String, password: String): void
        + logout(): void
        + getCurrentUser(): User
    }

    class BookingController {
        - bookingService: BookingService
        + BookingController(bookingService: BookingService)
        + pesanTiket(customer: Customer, schedule: Schedule, seat: String, harga: int): boolean
    }

    class ScheduleController {
        - scheduleService: ScheduleService
        + ScheduleController(scheduleService: ScheduleService)
        + addSchedule(mv: Movie, std: Studio, jamTayang: String): boolean
        + getAllSchedules(): List<Schedule>
        + getAllStudios(): List<Studio>
    }

    class MovieController {
        - movieService: MovieService
        + MovieController(movieRepo: MovieRepository)
        + addFilm(namaFilm: String, durasi: int, genre: String): boolean
        + deleteFilm(namaFilm: String): boolean
    }
}

package service {
    class AuthService {
        - userRepo: UserRepository
        + AuthService(repo: UserRepository)
        + login(username: String, password: String): User
        + logout(user: User): void
        + register(username: String, password: String, saldo: int, role: String): boolean
    }

    class BookingService {
        - tiketRepo: TiketRepository
        + BookingService(tiketRepo: TiketRepository)
        + isSeatAvailable(schedule: Schedule, seat: String): boolean
        + pesanTiket(customer: Customer, sch: Schedule, seat: String, harga: int): boolean
    }

    class ScheduleService {
        - scheduleRepo: ScheduleRepository
        + ScheduleService(scheduleRepo: ScheduleRepository)
        + addSchedule(mv: Movie, std: Studio, jamTayang: String): boolean
        + getAllSchedules(): List<Schedule>
        + getAllStudios(): List<Studio>
    }

    class MovieService {
        - movieRepo: MovieRepository
        + MovieService(movieRepo: MovieRepository)
        + addFilm(namaFilm: String, durasi: int, genre: String): boolean
        + deleteFilm(namaFilm: String): boolean
        + filterByGenre(genre: String): List<Movie>
    }
}

package repository {
    class UserRepository {
        - users: List<User>
        + UserRepository()
        + findByUsername(username: String): User
        + addUser(user: User): void
        + getAllUsers(): List<User>
    }

    class TiketRepository {
        - tikets: List<Tiket>
        + addTiket(): void
        + addTiket(tiket: Tiket): void
        + findTiket(datatiket: String): Tiket
        + getAllTiket(): List<Tiket>
        + findByUsername(username: String): List<Tiket>
    }

    class ScheduleRepository {
        - schdules: List<Schedule>
        - studios: List<Studio>
        + ScheduleRepository()
        + addSchedule(Movie mv)
        + getAllSchedules(): List<Schedule>
        + getAllStudios(): List<Studio>
    }

    class MovieRepository {
        - movieList: List<Movie>
        + MovieRepository()
        + findMovie(namaFilm: String): Movie
        + getAllMovies(): List<Movie>
        + addFilm(mv: Movie): void
        + deleteFilm(mv: Movie): void
    }
}

package model {
    abstract class User {
        - username: String
        - password: String
        - saldo: int
        + getRole(): String
        + getUsername(): String
        + getPassword(): String
        + getSaldo(): int
        + setSaldo(saldo: int): void
    }

    class Admin {
        + Admin(username: String, password: String, saldo: int)
        + getRole(): String
    }

    class Customer {
        + Customer(username: String, password: String, saldo: int)
        + getRole(): String
    }

    class Tiket {
        - tiketId: int
        - user: User
        - jadwalFilm: Schedule
        - seat: String
        - harga: int
        + Tiket(tiketId: int, user: User, jadwalFilm: Schedule, seat: String, harga: int)
        + getTiketId(): int
        + getUser(): User
        + getJadwalFilm(): Schedule
        + getSeat(): String
        + getHarga(): int
        + setTiketId(tiketId: int): void
        + setUser(user: User): void
        + setJadwalFilm(jadwalFilm: Schedule): void
        + setSeat(seat: String): void
        + setHarga(harga: int): void
        + printTiket(): void
    }

    class Schedule {
        - scheduleId: int
        - movie: Movie
        - studio: Studio
        - jamTayang: String
        + Schedule(scheduleId: int, movie: Movie, studio: Studio, jamTayang: String)
        + getScheduleId(): int
        + getMovie(): Movie
        + getStudio(): Studio
        + getJamTayang(): String
        + setScheduleId(scheduleId: int): void
        + setMovie(movie: Movie): void
        + setStudio(studio: Studio): void
        + setJamTayang(jamTayang: String): void
    }

    class Studio {
        - studioId: int
        - namaStudio: String
        - kapasitas: int
        - tipeStudio: String
        + Studio(studioId: int, namaStudio: String, kapasitas: int, tipeStudio: String)
        + getStudioId(): int
        + getNamaStudio(): String
        + getKapasitas(): int
        + getTipeStudio(): String
        + setStudioId(studioId: int): void
        + setNamaStudio(namaStudio: String): void
        + setKapasitas(kapasitas: int): void
        + setTipeStudio(tipeStudio: String): void
    }

    class Movie {
        - id: int
        - namaFilm: String
        - durasi: int
        - genre: String
        + Movie(id: int, namaFilm: String, durasi: int, genre: String)
        + getId(): int
        + getNamaFilm(): String
        + getDurasi(): int
        + getGenre(): String
        + setId(id: int): void
        + setNamaFilm(namaFilm: String): void
        + setDurasi(durasi: int): void
        + setGenre(genre: String): void
    }
}

Main --> AuthController

AuthController --> AuthService
BookingController --> BookingService
ScheduleController --> ScheduleService
MovieController --> MovieService

AuthService --> UserRepository
BookingService --> TiketRepository
ScheduleService --> ScheduleRepository
MovieService --> MovieRepository

UserRepository o-- User
TiketRepository o-- Tiket
ScheduleRepository o-- Schedule
ScheduleRepository o-- Studio
MovieRepository o-- Movie

User <|-- Admin
User <|-- Customer

Tiket --> User
Tiket --> Schedule
Schedule --> Movie
Schedule --> Studio

@enduml